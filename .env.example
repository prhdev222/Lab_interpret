# OpenRouter (API Key ซ่อนอยู่ที่ server เท่านั้น)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Turso Database
TURSO_URL=
TURSO_AUTH_TOKEN=

# Admin PIN ครั้งแรก (เปลี่ยนได้ทีหลังผ่านหน้า Admin)
DEFAULT_ADMIN_PIN=1234

# App URL (สำหรับ OpenRouter referrer)
APP_URL=https://your-app.deno.dev
